# WordPress GraphQL API URL (required)
WORDPRESS_API_URL=https://yoursitename.com/graphql

# Site URL (required). Must be set in production so the sitemap has correct absolute URLs.
PUBLIC_SITE_URL=https://yoursitename.com

# Social media integration (optional)
PUBLIC_DISQUS_EMBED_URL=https://siteid.disqus.com/embed.js
PUBLIC_X_SHARE_USER=your_x_handle

# Webhook-triggered revalidation (optional)
# Required for /api/revalidate; set a secret and send it in the x-revalidate-token header
REVALIDATE_TOKEN=your-secret-token
# Optional: Netlify build hook URL; when set, POST /api/revalidate will trigger a deploy
# NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/YOUR_HOOK_ID

# Web Vitals monitoring (optional)
# Set this to your analytics endpoint to collect Core Web Vitals metrics
PUBLIC_ANALYTICS_ENDPOINT=https://your-analytics-service.com/collect