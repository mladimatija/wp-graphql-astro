---
import MainLayout from "../layouts/MainLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getPosts } from "../lib/api";

const data = await getPosts(3);
---

<MainLayout title="Feedback received!">
	<div class="mb-12 text-center">
		<h1>Got it!</h1>
		<h2>
			Thank you for your feedback! I'll get back to you as soon as possible.
		</h2>
	</div>

	<p class="text-center font-bold">Up next - read some of the stuff I wrote:</p>
	<div class="mt-8 space-y-8">
		{
			data.posts.edges.map((post, i) => (
				<PostCard post={post.node} priority={i === 0} />
			))
		}
	</div>
</MainLayout>
