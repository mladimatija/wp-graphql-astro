---
import PostCard from "../components/PostCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
import Pagination from "../components/Pagination.astro";
import { getPosts, settingsQuery } from "../lib/api";

// Use the same page size as /page/2/ etc. so the homepage and the rest of the
// paginated archive line up.
const { allSettings } = (await settingsQuery()).data;
const postsPerPage = allSettings.readingSettingsPostsPerPage || 10;
const data = await getPosts(postsPerPage);
---

<MainLayout>
	<div class="space-y-8">
		{
			data.posts.edges.map((post, i) => (
				<PostCard post={post.node} priority={i === 0} />
			))
		}
	</div>
	<Pagination isHomepage={true} totalPosts={data.posts.pageInfo.total} />
</MainLayout>
