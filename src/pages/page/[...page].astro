---
import { Page } from "astro";
import { getPosts, settingsQuery } from "../../lib/api";
import PostCard from "../../components/PostCard.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import Pagination from "../../components/Pagination.astro";

// Set for static pre-rendering
export const prerender = true;

export async function getStaticPaths({ paginate }) {
	const { allSettings } = (await settingsQuery()).data;
	// Fetch ALL posts for static generation
	// Use the total count to determine how many posts to fetch
	const initialData = await getPosts();
	const totalPosts = initialData.posts.pageInfo.total;

	// Fetch all posts in one query
	const data = await getPosts(totalPosts, 1);

	return paginate(data.posts.edges, {
		pageSize: allSettings.readingSettingsPostsPerPage,
	});
}
let { page } = Astro.props;
---

<MainLayout>
	<div class="space-y-8">
		{
			page.data.map((post, i) => (
				<PostCard post={post.node} priority={i === 0} />
			))
		}
	</div>
	<Pagination page={page as Page} />
</MainLayout>
