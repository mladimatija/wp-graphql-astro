---
interface LinkedPost {
	title: string;
	uri: string;
}

interface Props {
	post: {
		previous?: LinkedPost;
		next?: LinkedPost;
	};
}

const { post } = Astro.props;
const paginationLinkClass =
	"post-link text-[var(--color-link)] no-underline transition-colors duration-300 hover:text-[var(--color-black)]";
---

<div class="post-pagination my-8">
	<p class="mb-6 text-center font-bold text-[var(--color-text)]">
		You've reached end of the line but you can check out some of the other
		articles I wrote:
	</p>

	<div
		class="post-pagination-container flex w-full flex-col gap-4 sm:flex-row sm:justify-between sm:gap-8"
	>
		{
			post.previous ? (
				<div class="post-pagination-prev min-w-0 flex-1 text-left sm:flex-none sm:max-w-[45%]">
					<span aria-hidden="true">«</span>{" "}
					<a href={post.previous.uri} rel="prev" class={paginationLinkClass}>
						{post.previous.title}
					</a>
				</div>
			) : (
				<div
					class="post-pagination-prev flex-1 sm:flex-none"
					aria-hidden="true"
				/>
			)
		}

		{
			post.next ? (
				<div class="post-pagination-next min-w-0 flex-1 text-right sm:flex-none sm:max-w-[45%]">
					<a href={post.next.uri} rel="next" class={paginationLinkClass}>
						{post.next.title}
					</a>{" "}
					<span aria-hidden="true">»</span>
				</div>
			) : (
				<div
					class="post-pagination-next flex-1 sm:flex-none"
					aria-hidden="true"
				/>
			)
		}
	</div>
</div>
