---
import type { CollectionEntry } from "astro:content";

interface Props {
	component: CollectionEntry<"components">;
}

const { component } = Astro.props;
const { data } = component.data;
---

<section
	class="newsletter-cta my-12 rounded-lg bg-[#f5f7fa] p-10 text-center"
	aria-labelledby="newsletter-heading"
>
	<div class="newsletter-content mx-auto max-w-[500px]">
		<h2 id="newsletter-heading" class="mb-3 text-[1.75rem] text-[#2c3e50]">
			{data.headline}
		</h2>
		<p class="mb-6 text-[#556575] leading-normal">{data.subheadline}</p>

		<form
			class="newsletter-form my-6 flex flex-col gap-4 sm:flex-row sm:[&_button]:shrink-0"
			method="post"
			name="newsletter-form"
			action="/success"
			netlify
		>
			<input type="hidden" name="form-name" value="newsletter-form" />
			<div class="form-group flex-1">
				<label for="email" class="sr-only">Email address</label>
				<input
					type="email"
					id="email"
					name="email"
					placeholder={data.placeholder}
					required
					aria-required="true"
					autocomplete="email"
					class="w-full rounded border border-gray-300 px-4 py-3 text-base"
				/>
			</div>

			<button
				type="submit"
				class="cursor-pointer rounded border-0 bg-[#4a76c4] px-6 py-3 text-base font-semibold text-white transition-colors duration-200 hover:bg-[#3a66b4] focus:outline-2 focus:outline-offset-2 focus:outline-[#3a66b4]"
			>
				{data.buttonText}
			</button>
		</form>

		<p class="privacy-notice mt-4 text-sm text-[#718096]">
			We respect your privacy. Unsubscribe at any time.
		</p>
	</div>
</section>
