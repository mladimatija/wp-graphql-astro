---
/**
 * Footer expects the resolved WordPress node as a prop from the page.
 */
interface FooterNode {
	__typename: string;
	title?: string;
	name?: string;
	uri?: string;
	link?: string;
	categories?: { nodes?: { name: string; uri: string }[] };
}

interface Props {
	node?: FooterNode | null;
}

const { node = null } = Astro.props;

const baseUrl = (
	import.meta.env.PUBLIC_SITE_URL || "https://example.com"
).replace(/\/$/, "");

const footerMetaLinkClass =
	"text-[var(--color-link)] no-underline transition-colors duration-300 hover:text-[var(--color-black)]";

// JSON-LD reads `items`; the HTML view renders the same list with anchors.
interface BreadcrumbItem {
	name: string;
	url: string;
	/** Whether the HTML view should render this as a link. The current page is plain text. */
	link?: boolean;
}

function buildBreadcrumbs(n: FooterNode | null): BreadcrumbItem[] {
	if (!n) return [];
	const items: BreadcrumbItem[] = [
		{ name: "Home", url: baseUrl + "/", link: true },
	];
	const type = n.__typename;
	if (type === "Tag" || type === "Category" || type === "Archive") {
		items.push({
			name:
				type === "Tag"
					? `Posts tagged "${n.name}"`
					: `Archive by category "${n.name}"`,
			url: baseUrl + (n.uri || "/"),
			link: false,
		});
	} else if (type === "Post" || type === "Page") {
		if (type === "Post" && n.categories?.nodes?.length) {
			items.push({
				name: n.categories.nodes[0].name,
				url: baseUrl + n.categories.nodes[0].uri,
				link: true,
			});
		}
		items.push({
			name: n.title || n.name || "",
			url: n.link || baseUrl + (n.uri || "/"),
			link: false,
		});
	}
	return items;
}

const breadcrumbItems = buildBreadcrumbs(node);
---

<footer
	class="footer mx-auto w-full max-w-3xl pt-3 text-center"
	transition:animate="fade"
>
	{
		breadcrumbItems.length > 1 && (
			<script
				type="application/ld+json"
				set:html={JSON.stringify({
					"@context": "https://schema.org",
					"@type": "BreadcrumbList",
					itemListElement: breadcrumbItems.map((item, i) => ({
						"@type": "ListItem",
						position: i + 1,
						name: item.name,
						item: item.url,
					})),
				})}
			/>
		)
	}
	{
		breadcrumbItems.length > 1 && (
			<div class="footer-breadcrumbs my-4" transition:animate="fade">
				<small class="text-[var(--color-text-muted)]">
					You are here:{" "}
					{breadcrumbItems.map((item, i) => (
						<>
							{i > 0 && " > "}
							{item.link ? <a href={item.url}>{item.name}</a> : item.name}
						</>
					))}
				</small>
			</div>
		)
	}
	<hr
		class="footer-separator my-4 border-0 border-t border-[var(--color-border)]"
	/>
	<small class="footer-built-with block text-xs text-[var(--color-text-muted)]">
		built with <a
			href="https://astro.build/"
			target="_blank"
			rel="noopener noreferrer"
			class={footerMetaLinkClass}>Astro</a
		>, headless WordPress and <a
			href="https://www.wpgraphql.com/"
			target="_blank"
			rel="noopener noreferrer"
			class={footerMetaLinkClass}>GraphQL</a
		>, hosted on <a
			href="https://www.netlify.com/"
			target="_blank"
			rel="noopener noreferrer"
			class={footerMetaLinkClass}>Netlify</a
		>
	</small>
</footer>
