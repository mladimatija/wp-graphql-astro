---
import { getNodeByURI } from "../lib/api";

const baseUrl = (
	import.meta.env.PUBLIC_SITE_URL || "https://example.com"
).replace(/\/$/, "");
const uri = `/${Astro.params.uri}/`;
const data = await getNodeByURI(uri);
const node = data.nodeByUri;

// Breadcrumb items for JSON-LD (and for building HTML)
function getBreadcrumbItems(n) {
	if (!n) return [];
	const items = [{ name: "Home", url: baseUrl + "/" }];
	const type = n.__typename;
	if (type === "Tag" || type === "Category" || type === "Archive") {
		items.push({
			name:
				type === "Tag"
					? `Posts tagged "${n.name}"`
					: `Archive by category "${n.name}"`,
			url: baseUrl + (n.uri || "/"),
		});
	} else if (type === "Post" || type === "Page") {
		if (type === "Post" && n.categories?.nodes?.length) {
			items.push({
				name: n.categories.nodes[0].name,
				url: baseUrl + n.categories.nodes[0].uri,
			});
		}
		items.push({
			name: n.title || n.name || "",
			url: n.link || baseUrl + (n.uri || "/"),
		});
	}
	return items;
}

const breadcrumbItems = getBreadcrumbItems(node);
const footerMetaLinkClass =
	"text-[var(--color-link)] no-underline transition-colors duration-300 hover:text-[var(--color-black)]";

// Simple breadcrumbs HTML, only one level deep (skip when no node)
const getBreadCrumbs = (n) => {
	if (!n) return "";
	const type = n.__typename;
	let out = 'You are here: <a href="/">Home</a> > ';

	if (type === "Tag" || type === "Category" || type === "Archive") {
		if (type === "Tag") {
			out += `Posts tagged "${n.name}"`;
		} else {
			out += `Archive by category "${n.name}"`;
		}
	} else if (type === "Post") {
		if (n.categories?.nodes?.length) {
			out += `<a href="${n.categories.nodes[0].uri}">${n.categories.nodes[0].name}</a> > `;
		}
	}

	out += n.title || "";

	return out;
};
---

<footer
	class="footer mx-auto w-full max-w-3xl pt-3 text-center"
	transition:animate="fade"
>
	{
		breadcrumbItems.length > 1 && (
			<script
				type="application/ld+json"
				set:html={JSON.stringify({
					"@context": "https://schema.org",
					"@type": "BreadcrumbList",
					itemListElement: breadcrumbItems.map((item, i) => ({
						"@type": "ListItem",
						position: i + 1,
						name: item.name,
						item: item.url,
					})),
				})}
			/>
		)
	}
	{
		Astro.params.uri !== undefined && node && getBreadCrumbs(node) && (
			<div class="footer-breadcrumbs my-4" transition:animate="fade">
				<small
					class="text-[var(--color-text-muted)]"
					set:html={getBreadCrumbs(node)}
				/>
			</div>
		)
	}
	<hr
		class="footer-separator my-4 border-0 border-t border-[var(--color-border)]"
	/>
	<small class="footer-built-with block text-xs text-[var(--color-text-muted)]">
		built with <a
			href="https://astro.build/"
			target="_blank"
			rel="noopener noreferrer"
			class={footerMetaLinkClass}>Astro</a
		>, headless WordPress and <a
			href="https://www.wpgraphql.com/"
			target="_blank"
			rel="noopener noreferrer"
			class={footerMetaLinkClass}>GraphQL</a
		>, hosted on <a
			href="https://www.netlify.com/"
			target="_blank"
			rel="noopener noreferrer"
			class={footerMetaLinkClass}>Netlify</a
		>
	</small>
</footer>
