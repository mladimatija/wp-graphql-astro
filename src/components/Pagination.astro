---
interface Props {
	isHomepage?: boolean;
	totalPosts?: number;
	page?: Page;
}

import { Page } from "astro";
import { settingsQuery } from "../lib/api";

const { allSettings } = (await settingsQuery()).data;
const { isHomepage, totalPosts, page } = Astro.props;

const postsPerPage = allSettings.readingSettingsPostsPerPage || 10;

// Total pages, computed lazily so missing/zero values fall back gracefully.
const computedLastPage = isHomepage
	? totalPosts
		? Math.max(1, Math.ceil(totalPosts / postsPerPage))
		: undefined
	: page?.lastPage;

function getPaginationText() {
	if (isHomepage) {
		return computedLastPage ? `Page 1 of ${computedLastPage}` : "Page 1";
	}
	if (page) {
		return computedLastPage
			? `Page ${page.currentPage} of ${computedLastPage}`
			: `Page ${page.currentPage}`;
	}
	return "";
}

// Show "Next »" only when there's a real next page.
const showNext = isHomepage
	? computedLastPage === undefined || computedLastPage > 1
	: Boolean(page && page.url?.next && page.currentPage < (page.lastPage ?? 0));

const nextHref = isHomepage ? "/page/2" : page?.url?.next || undefined;
---

<div
	class="pagination flex flex-wrap items-center justify-center gap-5 py-2 text-sm text-gray-800 [&>a]:text-[#29aae1] [&>a]:hover:underline [&>a]:hover:text-[#192226]"
>
	{
		!isHomepage && page?.url?.prev && (
			<a href={page.url.prev === "/page" ? "/" : page.url.prev}>« Prev</a>
		)
	}
	<span set:text={getPaginationText()} />
	{showNext && nextHref && <a href={nextHref}>Next »</a>}
</div>
