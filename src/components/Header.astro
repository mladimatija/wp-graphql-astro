---
import type { SettingsResponse, MenusResponse } from "../lib/api";
import Navigation from "../components/Navigation.astro";
import { settingsQuery } from "../lib/api";

interface Props {
	settings?: SettingsResponse;
	nav?: MenusResponse;
	showBlogTag?: boolean;
	/** When true, hide site name and "blog" so post title appears directly under logo */
	isSinglePost?: boolean;
}

const {
	settings: settingsProp,
	nav: navProp,
	showBlogTag = false,
	isSinglePost = false,
} = Astro.props;
const settingsResult = settingsProp
	? { data: settingsProp, fromFallback: false }
	: await settingsQuery();
const { generalSettings } = settingsResult.data;
const isHome = Astro.url.pathname === "/" || "page" in Astro.params;
/* On single post pages we don't show site name/blog so the post title sits directly under the logo */
const showSiteName = !isHome && !isSinglePost;
---

<header class="text-center" role="banner">
	<Navigation settings={settingsResult.data} nav={navProp} />
	<h1 class="flex flex-wrap justify-center">
		<a href="/" rel="home">
			<img
				class="block"
				src="/logo.svg"
				alt={`${generalSettings.title} logo`}
				width="192"
				height="192"
				fetchpriority="high"
				transition:name="logo"
			/>
		</a>
	</h1>

	{
		showSiteName && (
			<p class="header-site-name mt-2 text-lg font-semibold text-[var(--color-text)]">
				{generalSettings.title}
			</p>
		)
	}
	{
		showSiteName && showBlogTag && (
			<p class="header-tagline text-sm text-[var(--color-gray-600)]">blog</p>
		)
	}

	{
		isHome && ( // show only on the homepage
			<>
				<div class="header-description mt-4">
					<h1 class="text-[2em] font-bold leading-tight text-[var(--color-text)] max-[767px]:text-[1.3125rem]">
						Hi, I'm Matija, a senior software engineer (frontend & web)
					</h1>
					<h4 class="mt-3 text-base font-bold text-[var(--color-text)] max-[767px]:hidden">
						<a href="/about/" class="hover:underline">
							get to know me
						</a>
						, check out the{" "}
						<a
							href="https://www.linkedin.com/in/matijaculjak"
							target="_blank"
							title="Linkedin profile"
							class="hover:underline"
						>
							projects I worked on
						</a>{" "}
						or read on some of the stuff I wrote
					</h4>
				</div>
			</>
		)
	}
</header>
