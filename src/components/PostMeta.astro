---
import { FontAwesomeIcon } from "@fortawesome/react-fontawesome";
import { faClock } from "@fortawesome/free-regular-svg-icons";
import { stripHtml } from "string-strip-html";

interface Props {
	post: {
		content: string;
		date: string;
		dateGmt: string;
		[key: string]: unknown;
	};
	centered?: boolean;
}

const { post, centered = false } = Astro.props;

const estimatedReadingTime = (postContent: string) => {
	if (!postContent || postContent === "") {
		return "less than a minute read";
	}

	const wordCount = stripHtml(postContent).result.trim().split(/\s+/).length;
	const minutes = Math.trunc(wordCount / 250);

	if (minutes >= 1) {
		return `${minutes} minute${minutes === 1 ? "" : "s"} read`;
	} else {
		return "less than a minute read";
	}
};
---

{
	post && (
		<div
			class={`post-meta flex flex-wrap items-center gap-1.5 text-sm leading-none text-[var(--color-text-muted)] ${centered ? "justify-center" : ""}`}
		>
			<FontAwesomeIcon
				icon={faClock}
				size={"1x"}
				className="post-meta-icon h-4 w-4 shrink-0"
			/>
			<time datetime={post.dateGmt} class="post-date published">
				{new Date(post.date).toLocaleDateString()}
			</time>
			<span aria-hidden="true">-</span>
			<span>{estimatedReadingTime(post.content)}</span>
		</div>
	)
}
