{
	"name": "wp-graphql-astro",
	"type": "module",
	"version": "1.3.0",
	"private": false,
	"license": "MIT",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "astro dev",
		"start": "http-server ./dist",
		"build": "npm run build:branding && astro build && node fix-manifest.js && node src/scripts/generate-service-worker.js",
		"preview": "astro preview",
		"astro": "astro",
		"format": "prettier --write .",
		"lint:css": "stylelint \"src/**/*.{astro,css}\"",
		"lint:js": "eslint \"src/**/*.{js,ts}\"",
		"lint": "npm run lint:css && npm run lint:js",
		"clean": "rm -rf dist",
		"prebuild": "npm run clean",
		"build:branding": "node src/scripts/process-templates.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"fix-manifest": "node fix-manifest.js",
		"generate-sw": "node src/scripts/generate-service-worker.js",
		"prepare": "husky"
	},
	"dependencies": {
		"@astrojs/netlify": "^7.0.1",
		"@astrojs/react": "^5.0.0",
		"@astrojs/sitemap": "^3.7.1",
		"@fortawesome/fontawesome-svg-core": "^7.2.0",
		"@fortawesome/free-regular-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@fortawesome/react-fontawesome": "^3.2.0",
		"@tailwindcss/vite": "^4.2.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"astro": "^6.0.3",
		"astro-seo": "^1.1.0",
		"darkmode-js": "^1.5.7",
		"dotenv": "^17.3.1",
		"http-server": "^14.1.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.1",
		"web-vitals": "^5.1.0"
	},
	"overrides": {
		"lodash": ">=4.17.23"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@eslint/js": "^10.0.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"astro-eslint-parser": "^1.3.0",
		"autoprefixer": "^10.4.27",
		"cross-fetch": "^4.1.0",
		"cssnano": "^7.1.2",
		"eslint": "^9.39.3",
		"eslint-plugin-astro": "^1.6.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-react": "^7.37.4",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^16.3.2",
		"postcss": "^8.5.8",
		"postcss-cli": "^11.0.1",
		"postcss-html": "^1.8.1",
		"postcss-import": "^16.1.1",
		"postcss-preset-env": "^11.2.0",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1",
		"string-strip-html": "^13.5.3",
		"stylelint": "^17.4.0",
		"stylelint-config-standard": "^40.0.0",
		"typescript-eslint": "^8.56.1",
		"vitest": "^4.0.18"
	}
}
