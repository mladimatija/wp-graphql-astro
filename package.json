{
	"name": "wp-graphql-astro",
	"type": "module",
	"version": "1.4.0",
	"private": false,
	"license": "MIT",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"predev": "npm run build:branding",
		"dev": "astro dev",
		"start": "http-server ./dist",
		"build": "npm run build:branding && astro build && node fix-manifest.js && node src/scripts/generate-service-worker.js",
		"prepreview": "npm run build:branding",
		"preview": "astro preview",
		"astro": "astro",
		"format": "prettier --write .",
		"lint:css": "stylelint \"src/**/*.{astro,css}\"",
		"lint:js": "eslint \"src/**/*.{js,ts}\" \"*.js\" \"scripts/**/*.{js,ts}\"",
		"lint": "npm run lint:css && npm run lint:js",
		"clean": "rm -rf dist",
		"prebuild": "npm run clean",
		"build:branding": "node src/scripts/process-templates.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"fix-manifest": "node fix-manifest.js",
		"generate-sw": "node src/scripts/generate-service-worker.js",
		"prepare": "husky"
	},
	"dependencies": {
		"@astrojs/netlify": "^8.0.0",
		"@astrojs/react": "^6.0.0",
		"@astrojs/sitemap": "^3.7.3",
		"@fortawesome/fontawesome-svg-core": "^7.3.0",
		"@fortawesome/free-regular-svg-icons": "^7.3.0",
		"@fortawesome/free-solid-svg-icons": "^7.3.0",
		"@fortawesome/react-fontawesome": "^3.3.1",
		"@tailwindcss/vite": "^4.3.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"astro": "^7.0.3",
		"astro-seo": "^1.1.0",
		"darkmode-js": "^1.5.7",
		"dotenv": "^17.4.2",
		"http-server": "^14.1.1",
		"react": "^19.2.6",
		"react-dom": "^19.2.7",
		"tailwindcss": "^4.3.1",
		"web-vitals": "^5.3.0"
	},
	"overrides": {
		"lodash": ">=4.18.1",
		"uuid": ">=14.0.0",
		"yaml": ">=2.8.3",
		"vite": "^8.0.13",
		"@opentelemetry/core": "^2.8.0",
		"@opentelemetry/resources": "^2.8.0",
		"@opentelemetry/sdk-trace-base": "^2.8.0",
		"@opentelemetry/sdk-trace-node": "^2.8.0",
		"@netlify/edge-bundler": {
			"esbuild": "^0.28.1"
		},
		"@netlify/zip-it-and-ship-it": {
			"esbuild": "^0.28.1"
		}
	},
	"devDependencies": {
		"@commitlint/cli": "^21.1.0",
		"@commitlint/config-conventional": "^21.1.0",
		"@eslint/js": "^9.39.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"astro-eslint-parser": "^1.4.0",
		"autoprefixer": "^10.5.2",
		"cross-fetch": "^4.1.0",
		"cssnano": "^8.0.2",
		"eslint": "^9.39.4",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-react": "^7.37.4",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.8",
		"postcss": "^8.5.15",
		"postcss-cli": "^11.0.1",
		"postcss-html": "^1.8.1",
		"postcss-import": "^16.1.1",
		"postcss-preset-env": "^11.3.1",
		"prettier": "^3.9.0",
		"prettier-plugin-astro": "^0.14.1",
		"string-strip-html": "^13.5.3",
		"stylelint": "^17.14.0",
		"stylelint-config-standard": "^40.0.0",
		"typescript-eslint": "^8.62.0",
		"vitest": "^4.1.9"
	}
}
